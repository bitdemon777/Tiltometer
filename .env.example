# Скопируйте этот файл в .env и заполните значения.
# На хостинге задайте эти же переменные в настройках окружения (Environment).

# Общий пароль для входа в приложение (придумайте свой)
APP_PASSWORD=ourpoker2026

# Порт (хостинг обычно задаёт его сам; локально можно оставить 3000)
PORT=3000

# --- SMTP для отправки результатов на почту (ящик results@вашдомен.com на area.lv) ---
# Если не заполнить — приложение работает, но кнопка "Отправить результат" сообщит,
# что отправка не настроена.
SMTP_HOST=mail.вашдомен.com
SMTP_PORT=465
SMTP_USER=results@вашдомен.com
SMTP_PASS=пароль_от_почтового_ящика
# Адрес в поле "От кого" (по умолчанию совпадает с SMTP_USER)
SMTP_FROM=results@вашдомен.com
